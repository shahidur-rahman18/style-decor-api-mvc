# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<name>

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Firebase Admin — base64-encoded service account JSON (see serviceKeyConverter.js)
FB_SERVICE_KEY=

# Frontend URL (CORS + Stripe redirect URLs)
CLIENT_DOMAIN=http://localhost:5173

# Server (optional — defaults to 3000)
PORT=3000

# JWT — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
ACCESS_TOKEN_EXPIRY=15m

# Refresh Token
REFRESH_TOKEN_EXPIRY_DAYS=7

# Cookie
COOKIE_DOMAIN=localhost
NODE_ENV=development
